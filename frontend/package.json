{
  "name": "frontend",
  "private": true,
  "version": "0.2.1",
  "description": "HyperAgent personal AI assistant",
  "author": "HyperKindred",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "set HYPERAGENT_PORT=18080 && concurrently -k \"vite\" \"electron ../electron/main.cjs --dev\"",
    "electron:dev:wait": "set HYPERAGENT_PORT=18080 && concurrently -k \"vite\" \"wait-on http://localhost:5174 && electron ../electron/main.cjs --dev\"",
    "electron:start": "electron ../electron/main.cjs",
    "dist": "cd .. && call build-portable.bat --no-pause",
    "dist:dir": "cd .. && call build-portable.bat --no-pause"
  },
  "build": {
    "appId": "com.hyperagent.app",
    "productName": "HyperAgent",
    "copyright": "Copyright © 2026 HyperKindred",
    "directories": {
      "output": "../electron-dist"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "backend-resources",
        "to": "backend",
        "filter": ["**/*", "!**/.env"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../electron/icon.ico",
      "artifactName": "HyperAgent-${version}-portable.${ext}"
    }
  },
  "dependencies": {
    "@lucide/vue": "^1.18.0",
    "axios": "^1.17.0",
    "dompurify": "^3.4.11",
    "marked": "^18.0.5",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8",
    "wait-on": "^8.0.3"
  }
}
