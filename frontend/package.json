{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"electron ../electron/main.js --dev\"",
    "electron:dev:wait": "concurrently -k \"vite\" \"wait-on http://localhost:5174 && electron ../electron/main.js --dev\"",
    "electron:build": "vue-tsc -b && vite build && electron ../electron/main.js",
    "electron:start": "electron ../electron/main.js"
  },
  "dependencies": {
    "@lucide/vue": "^1.18.0",
    "axios": "^1.17.0",
    "marked": "^18.0.5",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8",
    "wait-on": "^8.0.3"
  }
}
