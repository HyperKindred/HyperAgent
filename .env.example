# ── LLM（聊天推理）— OpenAI 兼容接口 ─────────────────────────
# 推荐：https://opencode.ai/zen/go/v1（Go 套餐 $15/月）
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ── Vision（多模态图片理解）────────────────────────────────
# 留空则使用 LLM_MODEL 处理图片
VISION_MODEL=kimi-k2.6

# ── Embedding（向量化记忆 RAG）— OpenAI 兼容接口 ─────────────
# 推荐：https://openrouter.ai/api/v1（需申请 Key，用量极小）
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# ── GitHub 集成（可选）──────────────────────────────────────
GITHUB_TOKEN=your-github-token-here

# ── Notion 集成（可选）──────────────────────────────────────
NOTION_TOKEN=your-notion-token-here

# ── QQ 邮箱集成（可选）──────────────────────────────────────
QQ_EMAIL_ADDRESS=your-email@qq.com
QQ_EMAIL_AUTH_CODE=your-auth-code-here

# ── 天气 API（可选）─────────────────────────────────────────
WEATHER_API_KEY=your-weather-api-key-here
WEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ── 自定义搜索引擎（可选）──────────────────────────────────
# SEARCH_ENGINE_URL=https://your-searxng-instance.com/search

# ── 时区与日志 ──────────────────────────────────────────────
TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO
