# ── LLM（聊天推理）— OpenCode / OpenAI 兼容接口 ──────────────────────
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_API_KEY=your-opencode-api-key
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ── Vision（多模态图片理解）— 可选，留空则用 LLM_MODEL 兜底 ──────────
VISION_MODEL=kimi-k2.6

# ── Embedding（向量化记忆 RAG）— 可选，默认用 LLM 的 API ─────────────
# 记忆向量化用量极小。可复用 LLM_API_KEY（如果 API 支持 embedding），
# 或单独配置 OpenRouter / 其他 OpenAI 兼容 embedding API。
# EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# EMBEDDING_API_KEY=your-openrouter-api-key
# EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# ── GitHub 集成（可选）────────────────────────────────────────────────
# 创建 Personal Access Token → https://github.com/settings/tokens
# 需要 repo / issues / notifications 权限
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Notion 集成（可选）─────────────────────────────────────────────────
# 创建 Internal Integration Token → https://www.notion.so/profile/integrations
# 并在 Notion 中将需要访问的页面共享给该集成
# NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# ── QQ 邮箱集成（可选）─────────────────────────────────────────────────
# QQ 邮箱 → 设置 → 账户 → 开启 IMAP/SMTP → 生成授权码
# QQ_EMAIL_ADDRESS=yourname@qq.com
# QQ_EMAIL_AUTH_CODE=your-16-char-auth-code

# ── 天气 API（可选）───────────────────────────────────────────────────
# 免费注册：https://home.openweathermap.org/users/sign_up
# WEATHER_API_KEY=your-openweather-api-key
# WEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ── 自定义搜索引擎（可选）─────────────────────────────────────────────
# 默认用 DuckDuckGo → Bing 兜底。如果都不行，可指定 SearXNG 实例
# SEARCH_ENGINE_URL=https://your-searxng-instance.com/search

# ── 时区与日志 ────────────────────────────────────────────────────────
TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO
