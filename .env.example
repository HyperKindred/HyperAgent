# LLM (chat + tools) - OpenAI-compatible endpoint
# Packaged users should configure this in Settings; .env is for development.
PROVIDER=my_jarvis
LLM_BASE_URL=https://api.aijws.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-5.6-terra
LLM_REASONING_EFFORT=none
LLM_MAX_TOKENS=4096

# Vision uses LLM_MODEL unless this is disabled.
VISION_USE_SAME_MODEL=true
VISION_MODEL=

# Embedding memory retrieval. Auto probes the chat provider first, then fallback.
EMBEDDING_MODE=auto
EMBEDDING_AUTO_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# ── GitHub 集成（可选）──────────────────────────────────────
GITHUB_TOKEN=your-github-token-here

# ── Notion 集成（可选）──────────────────────────────────────
NOTION_TOKEN=your-notion-token-here

# ── QQ 邮箱集成（可选）──────────────────────────────────────
QQ_EMAIL_ADDRESS=your-email@qq.com
QQ_EMAIL_AUTH_CODE=your-auth-code-here

# ── 天气 API（可选）─────────────────────────────────────────
WEATHER_API_KEY=your-weather-api-key-here
WEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ── 自定义搜索引擎（可选）──────────────────────────────────
# SEARCH_ENGINE_URL=https://your-searxng-instance.com/search

# ── 时区与日志 ──────────────────────────────────────────────
TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO
